# GenAI Community EU — environment variables
# Copy to .env for local dev. In production these live in the Vercel project settings.

# --- Newsletter (Beehiiv) ---
# Beehiiv API key (Settings → API). Scope: subscriptions:write.
BEEHIIV_API_KEY=
# Beehiiv publication id (V2). The bare UUID or the pub_-prefixed form both work.
BEEHIIV_PUBLICATION_KEY_V2=pub_87fc77fb-cffd-4f30-8b8c-56db45a355c5

# --- Forms backend (server-side, secret) ---
# Resend API key — MUST be from the Resend account where the sender domain is verified.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Google reCAPTCHA Enterprise API key (Google Cloud API key with reCAPTCHA Enterprise enabled).
RECAPTCHA_API_KEY=

# Optional overrides (sensible defaults are baked in):
# RECAPTCHA_PROJECT_ID=my-tech-plan-1674492903312
# RECAPTCHA_SCORE_THRESHOLD=0.3                                       # lower = more lenient (privacy browsers)
# CONTACT_FROM_EMAIL=GenAI Community EU <noreply@genaicommunity.eu>   # must be a Resend-verified sender domain
# CONTACT_TO_EMAIL=hello@genaicommunity.eu
# SPONSOR_TO_EMAIL=hello@genaicommunity.eu
# NEWSLETTER_TO_EMAIL=hello@genaicommunity.eu                          # only used for the Beehiiv-failure fallback email

# --- Public (exposed to the browser, PUBLIC_ prefix) ---
# reCAPTCHA Enterprise site key (defaults to the shared My Tech Plan key).
PUBLIC_RECAPTCHA_SITE_KEY=6Lfjpl4sAAAAACd0hm3dgKL3rTA22WQi8uwYdAzX
# Analytics — leave empty to keep tags dormant. Set GenAI Community's own IDs to activate.
PUBLIC_GTM_ID=
PUBLIC_GA_MEASUREMENT_ID=
