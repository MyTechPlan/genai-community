---
// Provisional on-brand cover for blog posts (no image asset needed).
// `variant` shifts the iridescent glow so consecutive posts look distinct.
const { variant = 0 } = Astro.props;
const blobs = [
  { x: 70, y: 62, a: 115 },
  { x: 250, y: 70, a: 215 },
  { x: 168, y: 150, a: 320 },
  { x: 44, y: 150, a: 60 },
  { x: 280, y: 150, a: 255 },
];
const b = blobs[((variant % blobs.length) + blobs.length) % blobs.length];
const gid = `cov-iris-${variant}`;
const bid = `cov-blur-${variant}`;
---
<svg
  class="post-cover"
  viewBox="0 0 320 200"
  preserveAspectRatio="xMidYMid slice"
  role="img"
  aria-label="GenAI Community article cover"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id={gid} x1="0" y1="1" x2="1" y2="0" gradientTransform={`rotate(${b.a} 160 100)`}>
      <stop offset="0%" stop-color="#cfeede" />
      <stop offset="35%" stop-color="#e9e5f6" />
      <stop offset="60%" stop-color="#fbe2ef" />
      <stop offset="100%" stop-color="#d7ecf6" />
    </linearGradient>
    <filter id={bid} x="-60%" y="-60%" width="220%" height="220%">
      <feGaussianBlur stdDeviation="26" />
    </filter>
  </defs>

  <rect width="320" height="200" fill="#141416" />

  <!-- iridescent glow -->
  <circle cx={b.x} cy={b.y} r="78" fill={`url(#${gid})`} filter={`url(#${bid})`} opacity="0.5" />

  <!-- editorial hairline grid -->
  <g stroke="rgba(255,255,255,0.07)" stroke-width="1">
    <line x1="80" y1="0" x2="80" y2="200" />
    <line x1="160" y1="0" x2="160" y2="200" />
    <line x1="240" y1="0" x2="240" y2="200" />
    <line x1="0" y1="66" x2="320" y2="66" />
    <line x1="0" y1="133" x2="320" y2="133" />
  </g>

  <!-- dotted accent path -->
  <line x1="0" y1="133" x2="320" y2="66" stroke="rgba(255,255,255,0.22)" stroke-width="1" stroke-dasharray="2 6" />

  <!-- mini logo frame -->
  <g transform="translate(16,16)">
    <rect x="0" y="0" width="26" height="26" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.4" />
    <rect x="0.7" y="13.7" width="12.6" height="11.6" fill={`url(#${gid})`} opacity="0.85" />
  </g>

  <text x="16" y="186" font-family="'Spline Sans Mono', monospace" font-size="9" letter-spacing="2" fill="rgba(255,255,255,0.5)">GENAI · COMMUNITY</text>
</svg>

<style>
  .post-cover {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    border: 1px solid var(--line);
  }
</style>
