---
// Stylized map of chapter cities converging on Valencia (the annual summit anchor).
const cities = [
  { name: 'Lisbon', x: 48, y: 330 },
  { name: 'Madrid', x: 112, y: 295 },
  { name: 'Barcelona', x: 192, y: 278 },
  { name: 'Paris', x: 192, y: 148 },
  { name: 'London', x: 158, y: 92 },
  { name: 'Amsterdam', x: 222, y: 76 },
  { name: 'Berlin', x: 305, y: 92 },
  { name: 'Milan', x: 262, y: 198 },
];
const valencia = { name: 'Valencia', x: 152, y: 322 };
---
<svg
  viewBox="0 0 420 400"
  role="img"
  aria-label="Map of GenAI Community chapters across Europe converging on Valencia"
  class="constellation"
>
  {cities.map((c) => (
    <line x1={c.x} y1={c.y} x2={valencia.x} y2={valencia.y} class="link" />
  ))}
  {cities.map((c) => (
    <g>
      <circle cx={c.x} cy={c.y} r="5" class="node" />
      <text x={c.x + 10} y={c.y + 4} class="label">{c.name}</text>
    </g>
  ))}
  <defs>
    <linearGradient id="anchor-iris" x1="0" y1="1" x2="1" y2="0">
      <stop offset="0%" stop-color="#cdeede" />
      <stop offset="50%" stop-color="#fbe1ef" />
      <stop offset="100%" stop-color="#d6ecf6" />
    </linearGradient>
  </defs>
  <circle cx={valencia.x} cy={valencia.y} r="14" class="anchor-halo" />
  <circle cx={valencia.x} cy={valencia.y} r="7" class="anchor" />
  <text x={valencia.x - 8} y={valencia.y + 28} class="label label-anchor">Valencia</text>

  <style>
    .constellation {
      width: 100%;
      height: auto;
      overflow: visible;
    }
    .link {
      stroke: rgba(255, 255, 255, 0.18);
      stroke-width: 1.2;
      stroke-dasharray: 4 5;
    }
    .node { fill: var(--text-dim); }
    .anchor { fill: url(#anchor-iris); }
    .anchor-halo {
      fill: none;
      stroke: #fbe1ef;
      stroke-width: 1.5;
      opacity: 0.6;
      animation: halo 2.6s ease-out infinite;
      transform-origin: center;
    }
    @keyframes halo {
      0% { r: 10; opacity: 0.7; }
      100% { r: 22; opacity: 0; }
    }
    .label {
      font-family: var(--font-mono);
      font-size: 11px;
      fill: var(--text-faint);
    }
    .label-anchor {
      fill: var(--text);
      font-weight: 500;
    }
    @media (prefers-reduced-motion: reduce) {
      .anchor-halo { animation: none; opacity: 0.4; }
    }
  </style>
</svg>
