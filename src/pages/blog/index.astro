---
import Base from '../../layouts/Base.astro';
import Newsletter from '../../components/Newsletter.astro';
---
<Base title="Blog - GenAI Community EU" description="Expert posts on generative AI in production, written by the European community. Coming soon.">
  <section class="section">
    <div class="wrap">
      <div class="soon-wrap">
        <span class="eyebrow">Blog</span>
        <h1>Coming <span class="grad">soon</span></h1>
        <p class="lede">We're lining up the first posts — practitioners writing about building with generative AI: agents, evals, infra, and what actually survives contact with production.</p>
        <p class="soon-sub">Want to be the first to read them? Join the newsletter below. Want to write one? We'd love to hear from you.</p>
        <div class="soon-ctas">
          <a href="/#newsletter" class="btn btn-iris">Join the newsletter</a>
          <a href="mailto:blog@genaicommunity.eu?subject=I want to write for the blog" class="btn btn-ghost">Apply to be a writer</a>
        </div>
      </div>
    </div>
  </section>
  <Newsletter />

  <style>
    .soon-wrap { max-width: 40rem; }
    .lede { font-size: 1.2rem; color: var(--text-dim); margin-top: 0.5rem; }
    .soon-sub { color: var(--text-dim); }
    .soon-ctas {
      display: flex;
      gap: 0.8rem;
      margin-top: 1.8rem;
      flex-wrap: wrap;
    }
  </style>
</Base>
