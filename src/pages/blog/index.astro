---
import Base from '../../layouts/Base.astro';
import Newsletter from '../../components/Newsletter.astro';
import PostCover from '../../components/PostCover.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---
<Base title="Blog - GenAI Community EU" description="Expert posts on generative AI in production, written by the European community.">
  <section class="section">
    <div class="wrap">
      <span class="eyebrow">Blog</span>
      <h1>Notes from the field</h1>
      <p class="lede">Posts by community experts on building with generative AI - agents, evals, infra, and what actually survives contact with production.</p>

      <div class="post-list">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-row">
            <PostCover variant={i} />
            <div>
              <p class="post-date">{post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</p>
              <h2>{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <p class="post-author">{post.data.author}{post.data.authorRole ? ` - ${post.data.authorRole}` : ''}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="write-cta">
        <p><strong>Want to publish here?</strong> We're looking for practitioners with real stories - wins, failures, and everything in between.</p>
        <a href="mailto:blog@genaicommunity.eu?subject=I want to write for the blog" class="btn btn-iris">Apply to be a writer</a>
      </div>
    </div>
  </section>
  <Newsletter />

  <style>
    .lede { font-size: 1.15rem; color: var(--text-dim); max-width: 38rem; }
    .post-list { margin-top: 3rem; display: flex; flex-direction: column; }
    .post-row {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 1.8rem;
      padding: 1.9rem 0;
      border-top: 1px solid var(--line);
      text-decoration: none;
      color: var(--text);
      align-items: center;
    }
    .post-row :global(.post-cover) { transition: border-color 140ms ease; }
    .post-row:hover :global(.post-cover) { border-color: var(--line-2); }
    .post-row:hover h2 { color: var(--text); opacity: 0.7; }
    .post-row h2 { font-size: 1.4rem; margin-bottom: 0.4rem; transition: opacity 120ms ease; }
    .post-date {
      font-family: var(--font-mono);
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-faint);
      margin-bottom: 0.5rem;
    }
    .post-desc { color: var(--text-dim); }
    .post-author { font-size: 0.85rem; font-weight: 600; color: var(--text-dim); margin: 0.5rem 0 0; }
    .write-cta {
      margin-top: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      background: var(--bg-2);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 1.5rem 2rem;
    }
    .write-cta p { margin: 0; color: var(--text-dim); }
    .write-cta strong { color: var(--text); }
    @media (max-width: 640px) {
      .post-row { grid-template-columns: 1fr; gap: 0.3rem; }
    }
  </style>
</Base>
