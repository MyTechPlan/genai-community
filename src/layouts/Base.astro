---
import '../styles/global.css';
import Logo from '../components/Logo.astro';
import CookieBanner from '../components/CookieBanner.astro';
import Analytics from '@vercel/analytics/astro';
const SITE_NAME = 'GenAI Community EU';
const SITE_DESCRIPTION = 'The European community of generative AI builders and practitioners. Chapters across Europe, expert blog, weekly newsletter, and one annual summit in Valencia.';

const {
  title = 'GenAI Community EU',
  description = SITE_DESCRIPTION,
  ogImage = '/og-image.png',
  ogType = 'website',
  noindex = false,
} = Astro.props;

// SEO — derived per page from props + the site URL set in astro.config.mjs.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': new URL('/#organization', Astro.site).toString(),
  name: SITE_NAME,
  legalName: 'My Tech Plan, S.L.',
  url: Astro.site.toString(),
  logo: new URL('/icon-512.png', Astro.site).toString(),
  image: new URL('/og-image.png', Astro.site).toString(),
  description: SITE_DESCRIPTION,
  slogan: "Where Europe's GenAI builders actually meet",
  sameAs: [
    'https://x.com/GenAISummit_EU',
    'https://www.linkedin.com/company/genai-community-eu/',
    'https://genaisummit.eu',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': new URL('/#website', Astro.site).toString(),
  name: SITE_NAME,
  url: Astro.site.toString(),
  description: SITE_DESCRIPTION,
  inLanguage: 'en',
  publisher: { '@id': new URL('/#organization', Astro.site).toString() },
};

// Analytics IDs (dormant until provided). Same Consent-Mode-v2 + GTM + GA4 wiring as site-blog.
const GTM_ID = import.meta.env.PUBLIC_GTM_ID || '';
const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || '';
// reCAPTCHA Enterprise site key (reused from My Tech Plan; override via env if a dedicated key is created).
const RECAPTCHA_SITE_KEY = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '6Lfjpl4sAAAAACd0hm3dgKL3rTA22WQi8uwYdAzX';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical + indexing -->
    <link rel="canonical" href={canonicalURL} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large" />}

    <!-- Open Graph (Facebook, LinkedIn, Slack, Discord, WhatsApp) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="GenAI Community EU — where Europe's GenAI builders actually meet" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@GenAISummit_EU" />
    <meta name="twitter:creator" content="@GenAISummit_EU" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="GenAI Community EU — where Europe's GenAI builders actually meet" />

    <!-- Favicons & app icons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0b0b0c" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Instrument+Sans:wght@400;500;600&family=Space+Grotesk:wght@400;500;700&family=Spline+Sans+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Google Consent Mode v2 — MUST run before any Google tags -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }

      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        functionality_storage: 'granted',
        security_storage: 'granted',
        wait_for_update: 500,
      });

      (function () {
        try {
          var saved = localStorage.getItem('gc_cookie_consent');
          if (saved) {
            var consent = JSON.parse(saved);
            gtag('consent', 'update', {
              analytics_storage: consent.analytics ? 'granted' : 'denied',
              ad_storage: consent.marketing ? 'granted' : 'denied',
              ad_user_data: consent.marketing ? 'granted' : 'denied',
              ad_personalization: consent.marketing ? 'granted' : 'denied',
            });
          }
        } catch (e) {}
      })();
    </script>

    {GTM_ID && (
      <script is:inline define:vars={{ GTM_ID }}>
        (function (w, d, s, l, i) {
          w[l] = w[l] || [];
          w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var f = d.getElementsByTagName(s)[0],
            j = d.createElement(s),
            dl = l != 'dataLayer' ? '&l=' + l : '';
          j.async = true;
          j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
          f.parentNode.insertBefore(j, f);
        })(window, document, 'script', 'dataLayer', GTM_ID);
      </script>
    )}

    {GA_MEASUREMENT_ID && (
      <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
        (function () {
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_MEASUREMENT_ID;
          document.head.appendChild(s);
          gtag('js', new Date());
          gtag('config', GA_MEASUREMENT_ID);
        })();
      </script>
    )}

    <!-- reCAPTCHA Enterprise (loaded for all forms) -->
    <script is:inline define:vars={{ RECAPTCHA_SITE_KEY }}>
      window.__RECAPTCHA_SITE_KEY = RECAPTCHA_SITE_KEY;
      (function () {
        if (!RECAPTCHA_SITE_KEY) return;
        var s = document.createElement('script');
        s.src = 'https://www.google.com/recaptcha/enterprise.js?render=' + RECAPTCHA_SITE_KEY;
        s.async = true;
        s.defer = true;
        document.head.appendChild(s);
      })();
    </script>
  </head>
  <body>
    {GTM_ID && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}
    <header class="site-header">
      <div class="wrap nav">
        <a href="/" class="logo" aria-label="GenAI Community EU home">
          <Logo size={40} decorative={true} />
        </a>
        <nav aria-label="Main">
          <a href="/">Home</a>
          <a href="/blog">Blog</a>
          <a href="/chapters">Chapters</a>
          <a href="/#summit">Summit</a>
          <a href="/#newsletter" class="nav-cta">Newsletter</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-grid">
        <div class="footer-brand">
          <div class="footer-logo"><Logo size={52} /></div>
          <p class="footer-tag">Built by practitioners, across Europe.<br />Annual gathering at <a href="https://genaisummit.eu" class="link-holo" rel="noopener" target="_blank">GenAI Summit EU</a>, Valencia.</p>
          <a href="/sponsor" class="btn btn-iris footer-contact">Become a sponsor</a>
        </div>
        <nav class="footer-links" aria-label="Footer">
          <a href="/blog">Blog</a>
          <a href="/chapters">Chapters</a>
          <a href="https://genaisummit.eu" rel="noopener">GenAI Summit EU</a>
          <a href="/#newsletter">Newsletter</a>
          <a href="/contact">Contact</a>
          <a href="/privacy">Privacy</a>
          <button type="button" class="footer-static footer-cookie-btn" data-manage-cookies>Manage cookies</button>
        </nav>
      </div>
      <div class="wrap footer-bottom">
        <div class="social">
          <span class="social-label">Follow us</span>
          <a href="https://x.com/GenAISummit_EU" class="social-ic" aria-label="Follow us on X" rel="noopener" target="_blank">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/genai-community-eu/" class="social-ic" aria-label="Follow us on LinkedIn" rel="noopener" target="_blank">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>
          </a>
          <a href="https://join.slack.com/t/genaicommunityespacio/shared_invite/zt-40tgj84ep-ON4753OHsvJYI8A0iy923Q" class="social-ic" aria-label="Join us on Slack" rel="noopener" target="_blank">
            <svg viewBox="0 0 122.8 122.8" aria-hidden="true"><path d="M25.8 77.6c0 7.1-5.8 12.9-12.9 12.9S0 84.7 0 77.6s5.8-12.9 12.9-12.9h12.9v12.9zM32.3 77.6c0-7.1 5.8-12.9 12.9-12.9s12.9 5.8 12.9 12.9v32.3c0 7.1-5.8 12.9-12.9 12.9s-12.9-5.8-12.9-12.9V77.6z"/><path d="M45.2 25.8c-7.1 0-12.9-5.8-12.9-12.9S38.1 0 45.2 0s12.9 5.8 12.9 12.9v12.9H45.2zM45.2 32.3c7.1 0 12.9 5.8 12.9 12.9s-5.8 12.9-12.9 12.9H12.9C5.8 58.1 0 52.3 0 45.2s5.8-12.9 12.9-12.9h32.3z"/><path d="M97 45.2c0-7.1 5.8-12.9 12.9-12.9s12.9 5.8 12.9 12.9-5.8 12.9-12.9 12.9H97V45.2zM90.5 45.2c0 7.1-5.8 12.9-12.9 12.9s-12.9-5.8-12.9-12.9V12.9C64.7 5.8 70.5 0 77.6 0s12.9 5.8 12.9 12.9v32.3z"/><path d="M77.6 97c7.1 0 12.9 5.8 12.9 12.9s-5.8 12.9-12.9 12.9-12.9-5.8-12.9-12.9V97h12.9zM77.6 90.5c-7.1 0-12.9-5.8-12.9-12.9s5.8-12.9 12.9-12.9h32.3c7.1 0 12.9 5.8 12.9 12.9s-5.8 12.9-12.9 12.9H77.6z"/></svg>
          </a>
        </div>
        <p class="copyright">Made with love &amp; Claude &lt;3 · All rights reserved · © {new Date().getFullYear()} <a href="https://www.mytechplan.com" class="link-holo" target="_blank" rel="noopener">My Tech Plan S.L</a></p>
      </div>
    </footer>

    <CookieBanner />

    <script>
      import { wireAllForms } from '../scripts/form-submit.js';

      function init() {
        wireAllForms();
        const manageBtn = document.querySelector('[data-manage-cookies]');
        if (manageBtn) {
          manageBtn.addEventListener('click', () => {
            window.dispatchEvent(new CustomEvent('showCookieBanner'));
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>

    <Analytics />

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: color-mix(in srgb, var(--bg) 72%, transparent);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--line);
      }
      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .logo {
        color: var(--text);
        text-decoration: none;
        display: flex;
        align-items: center;
        line-height: 0;
      }
      .logo .gc-logo { display: block; }
      nav[aria-label="Main"] {
        display: flex;
        gap: 1.4rem;
        align-items: center;
      }
      nav[aria-label="Main"] a {
        color: var(--text-dim);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
      }
      nav[aria-label="Main"] a:hover { color: var(--text); }
      .nav-cta {
        background-image: var(--iris);
        background-size: 220% 220%;
        background-position: 0% 50%;
        animation: irisShift 6s ease-in-out infinite;
        color: #14131a !important;
        font-weight: 600 !important;
        padding: 0.45rem 1rem;
        border-radius: 6px;
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.25) inset;
      }
      .nav-cta:hover { animation-duration: 2.8s; }

      .site-footer {
        background: var(--bg-1);
        color: var(--text-dim);
        border-top: 1px solid var(--line);
        padding: 3.5rem 0 1.5rem;
      }
      .footer-grid {
        display: flex;
        justify-content: space-between;
        align-items: stretch;
        gap: 2rem;
        flex-wrap: wrap;
      }
      .footer-brand { display: flex; flex-direction: column; }
      .footer-contact { margin-top: auto; align-self: flex-start; }
      .footer-logo {
        color: var(--text);
        line-height: 0;
        margin-bottom: 0.9rem;
      }
      .footer-logo .gc-logo { display: block; }
      .footer-tag { color: var(--text-dim); font-size: 0.95rem; }
      .footer-links { display: flex; flex-direction: column; gap: 0.5rem; }
      .footer-links a { color: var(--text-dim); text-decoration: none; }
      .footer-links a[href]:hover { color: var(--text); }
      .footer-static { color: var(--text-dim); }
      .footer-cookie-btn {
        background: none;
        border: none;
        padding: 0;
        font: inherit;
        text-align: left;
        cursor: pointer;
      }
      .footer-cookie-btn:hover { color: var(--text); }
      .copyright .link-holo { font-weight: 400; }
      .footer-bottom {
        margin-top: 2.5rem;
        padding-top: 1.2rem;
        border-top: 1px solid var(--line);
        font-size: 0.85rem;
        color: var(--text-faint);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .copyright { margin: 0; }
      .social { display: flex; align-items: center; gap: 0.85rem; }
      .social-label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--text-faint);
      }
      .social-ic { color: var(--text-dim); display: inline-flex; transition: color 120ms ease; }
      .social-ic svg { width: 17px; height: 17px; fill: currentColor; display: block; }
      .social-ic:hover { color: var(--text); }
      @media (max-width: 640px) {
        nav[aria-label="Main"] { gap: 0.9rem; font-size: 0.9rem; }
      }
    </style>
  </body>
</html>
